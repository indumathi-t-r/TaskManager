{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Connection string for SQLite.
  // "taskmanager.db" will be created as a file in your project root.
  // SQLite is a file-based database - perfect for learning and small projects.
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=taskmanager.db"
  },

  // JWT configuration
  "JwtSettings": {
    // Secret key used to SIGN the token - must be at least 32 characters long.
    // IMPORTANT: In a real production app, never put this in appsettings.json!
    // Use environment variables or Azure Key Vault instead.
    // For learning purposes, it's fine here.
    "Secret": "YourSuperSecretKeyForJWTTokenGeneration_MustBe32CharsOrMore!",

    // Who issues the token (your app's name/URL)
    "Issuer": "TaskManagerAPI",

    // Who the token is for (your frontend app)
    "Audience": "TaskManagerAPI",

    // How many hours until the token expires
    // After this, the user must log in again
    "ExpiresInHours": 24
  }
}
